# PostgreSQL（Vercel / Neon 等；本地可用 Docker 或 Neon 免费库）
# 本地 Docker 示例: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=trailpack -e POSTGRES_DB=trailpack postgres:16
DATABASE_URL="postgresql://postgres:trailpack@localhost:5432/trailpack"

# Auth.js — 生成: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# 应用 URL（Vercel 部署后改为 https://你的项目.vercel.app）
AUTH_URL="http://localhost:3001"

# Vercel Blob — 装备图片上传（Storage → Blob → 创建 Store → 复制 Token）
BLOB_READ_WRITE_TOKEN=""

# GitHub OAuth（可选，未配置时仅邮箱登录）
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# DeepSeek（OpenAI 兼容）；未配置时使用规则模板演示模式
# 在 https://platform.deepseek.com/api_keys 创建密钥
DEEPSEEK_API_KEY=""

DEEPSEEK_BASE_URL="https://api.deepseek.com"

# 模型：deepseek-reasoner（思考模式，推荐）| deepseek-chat（快速）
DEEPSEEK_MODEL="deepseek-reasoner"

# 思考模式：true 启用链式推理（reasoner 模型始终开启）
DEEPSEEK_THINKING_ENABLED="true"

# 推理强度（可选）：high | max，仅思考模式生效
DEEPSEEK_REASONING_EFFORT="high"

# 微信小程序
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
# 开发环境允许 /api/mp/auth/dev-login（未配置微信时小程序自动降级）
MP_DEV_LOGIN="true"
