.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1b4332;
  margin-bottom: 8rpx;
}

.input-area {
  width: 100%;
  min-height: 280rpx;
  margin: 24rpx 0 16rpx;
  padding: 24rpx;
  background: rgba(255, 252, 245, 0.86);
  border: 1rpx solid rgba(27, 67, 50, 0.12);
  border-radius: 20rpx;
  color: #1b4332;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 8rpx rgba(27, 67, 50, 0.03);
}

.example-btn {
  margin-bottom: 8rpx;
}

.form-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #5c6b5a;
  line-height: 1.5;
}
