.trip-desc {
  color: #5c6b5a;
  font-size: 26rpx;
  line-height: 1.55;
}

.tags { margin: 16rpx 0; }

.actions {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.mini-btn { flex: 1; font-size: 26rpx; }

.status {
  display: block;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.section-title {
  color: #2d6a4f;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-item {
  width: 30%;
  font-size: 24rpx;
  color: #1b4332;
}

.label {
  display: block;
  color: #5c6b5a;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

/* AI 思考面板 — 林冠绿调，非暗色 */
.thinking {
  border-color: rgba(45, 106, 79, 0.18);
  background: rgba(232, 245, 214, 0.55);
}

.thinking-head {
  display: flex;
  justify-content: space-between;
  color: #1b4332;
  font-weight: 600;
  font-size: 26rpx;
}

.thinking-body {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #3d5248;
  white-space: pre-wrap;
  line-height: 1.55;
}

/* 风险与天气 — 日光琥珀 */
.warn {
  border-color: rgba(212, 160, 23, 0.35);
  background: rgba(255, 251, 235, 0.92);
}

.warn-title { color: #b45309; }

.warn-text {
  display: block;
  font-size: 24rpx;
  color: #92400e;
  margin-bottom: 8rpx;
  white-space: pre-wrap;
  line-height: 1.5;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx 0 16rpx;
}

.category-block { margin-bottom: 24rpx; }

.category-title {
  color: #2d6a4f;
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.item-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 252, 245, 0.72);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(27, 67, 50, 0.04);
}

.item-info { flex: 1; min-width: 0; }

.item-name-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}

.checked {
  color: #9ca89a;
  text-decoration: line-through;
}

.item-reason {
  font-size: 22rpx;
  display: block;
  margin-top: 4rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.edit-link {
  color: #d4a017;
  font-size: 24rpx;
  font-weight: 600;
}

.flags { margin-top: 12rpx; }

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(27, 67, 50, 0.08);
}

.form-input {
  flex: 1;
  text-align: right;
  color: #1b4332;
  font-size: 26rpx;
}

.picker-val {
  color: #2d6a4f;
  font-size: 26rpx;
  font-weight: 500;
}

.switch-row { padding: 12rpx 0; }

.save-btn { margin-top: 24rpx; }

.list-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
}

.team-card { margin-bottom: 16rpx; }

.team-role {
  color: #1b4332;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.team-item {
  display: block;
  font-size: 24rpx;
  color: #5c6b5a;
  margin-bottom: 4rpx;
  line-height: 1.45;
}

.share-btn { flex: 0 0 auto !important; min-width: 120rpx; }

.delete-btn {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #dc2626;
  background: rgba(254, 242, 242, 0.6);
  border: 1rpx solid rgba(220, 38, 38, 0.25);
}

.version-picker {
  color: #2d6a4f;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: rgba(232, 245, 214, 0.7);
  border-radius: 12rpx;
}

.progress-wrap { margin: 16rpx 0 24rpx; }

.progress-bar {
  height: 12rpx;
  background: rgba(232, 245, 214, 0.9);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2d6a4f, #52b788);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  display: block;
  font-size: 22rpx;
  color: #5c6b5a;
  margin-top: 8rpx;
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(232, 245, 214, 0.7);
  color: #5c6b5a;
}

.filter-btn.active {
  background: #1b4332;
  color: #f7fbf4;
  font-weight: 600;
}

.owned-btn {
  font-size: 22rpx;
  color: #5c6b5a;
  padding: 8rpx 12rpx;
  border: 1rpx solid rgba(27, 67, 50, 0.12);
  border-radius: 10rpx;
  flex-shrink: 0;
  align-self: center;
}

.owned-btn.owned-active {
  color: #2d6a4f;
  border-color: rgba(45, 106, 79, 0.35);
  background: rgba(232, 245, 214, 0.95);
  font-weight: 600;
}

.owned-row { opacity: 0.78; }
