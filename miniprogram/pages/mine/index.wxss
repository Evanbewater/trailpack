.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 40rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: rgba(232, 245, 214, 0.95);
  border: 1rpx solid rgba(45, 106, 79, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(27, 67, 50, 0.06);
}

.avatar {
  font-size: 56rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 20rpx;
  color: #1b4332;
}

.meta {
  font-size: 22rpx;
  margin-top: 8rpx;
  color: #5c6b5a;
}

.stats {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
}

.stat-item { text-align: center; }

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #d4a017;
  letter-spacing: -0.02em;
}

.stat-label {
  font-size: 24rpx;
  color: #5c6b5a;
  margin-top: 4rpx;
}

.section-title {
  color: #2d6a4f;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.about {
  display: block;
  font-size: 24rpx;
  margin-bottom: 8rpx;
  color: #5c6b5a;
  line-height: 1.5;
}

.logout {
  margin-top: 16rpx;
  color: #dc2626;
  border-color: rgba(220, 38, 38, 0.25);
  background: rgba(254, 242, 242, 0.5);
}

.nav-card {
  position: relative;
  margin-bottom: 24rpx;
}

.nav-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #d4a017;
  font-size: 32rpx;
  font-weight: 600;
}

.mine-header {
  margin-bottom: 8rpx;
  padding: 0 0 8rpx;
}

.mine-header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1b4332;
}

.mine-header-hint {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5c6b5a;
}
