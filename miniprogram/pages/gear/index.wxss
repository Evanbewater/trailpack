.head { margin-bottom: 20rpx; }

/* ── 添加/编辑装备表单 ── */
.form-card {
  margin-top: 24rpx;
  padding: 28rpx 28rpx 32rpx;
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1b4332;
  margin-bottom: 28rpx;
}

.image-upload {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
}

.gear-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(27, 67, 50, 0.12);
}

.image-remove {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 600;
}

.image-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(27, 67, 50, 0.2);
  background: rgba(255, 252, 245, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.image-placeholder-icon {
  font-size: 40rpx;
  opacity: 0.7;
}

.image-placeholder-text {
  font-size: 22rpx;
  color: #5c6b5a;
}

.image-pick-btn {
  font-size: 24rpx;
  padding: 16rpx 24rpx;
}

.image-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca89a;
}

.gear-list-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(27, 67, 50, 0.1);
}

.gear-list-thumb--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(232, 245, 214, 0.8);
  font-size: 32rpx;
  color: #5c6b5a;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #5c6b5a;
  margin-bottom: 10rpx;
}

.field-box {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: rgba(255, 252, 245, 0.95);
  border: 1rpx solid rgba(27, 67, 50, 0.12);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.field-input {
  flex: 1;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #1b4332;
  background: transparent;
}

.field-placeholder {
  color: #9ca89a;
  font-size: 28rpx;
}

.field-picker {
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #1b4332;
  font-weight: 500;
}

.picker-arrow {
  font-size: 24rpx;
  color: #d4a017;
  margin-left: 16rpx;
}

.field-weight {
  padding-right: 20rpx;
}

.weight-unit {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #5c6b5a;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.form-actions .mini {
  flex: 1;
  font-size: 28rpx;
  margin: 0;
  padding: 22rpx 0;
  line-height: 1.4;
}

.form-error {
  display: block;
  margin-top: 16rpx;
  text-align: center;
}

/* ── 列表与其它 ── */
.empty {
  margin-top: 32rpx;
  text-align: center;
  color: #5c6b5a;
  font-size: 26rpx;
}

.empty-btn { margin-top: 24rpx; }

/* ── 分类筛选与版块 ── */
.cat-tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin: 24rpx 0 8rpx;
  padding: 6rpx 0;
}

.cat-tab {
  display: inline-flex;
  flex-shrink: 0;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5c6b5a;
  background: rgba(232, 245, 214, 0.65);
  border: 1rpx solid transparent;
}

.cat-tab.active {
  color: #1b4332;
  font-weight: 600;
  background: rgba(255, 252, 245, 0.95);
  border-color: rgba(212, 160, 23, 0.35);
  box-shadow: 0 2rpx 12rpx rgba(27, 67, 50, 0.06);
}

.cat-block {
  margin-top: 20rpx;
  padding-top: 8rpx;
}

.cat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  margin-bottom: 4rpx;
  border-bottom: 1rpx solid rgba(27, 67, 50, 0.08);
}

.cat-title {
  color: #1b4332;
  font-weight: 600;
  font-size: 28rpx;
}

.cat-count {
  font-size: 22rpx;
  color: #5c6b5a;
  background: rgba(232, 245, 214, 0.8);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.gear-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(27, 67, 50, 0.08);
}

.gear-row:last-child { border-bottom: none; }

.gear-row.selected {
  background: rgba(232, 245, 214, 0.5);
  border-radius: 12rpx;
  margin: 0 -8rpx;
  padding: 16rpx 8rpx;
}

.gear-info { flex: 1; min-width: 0; }

.gear-name {
  display: block;
  color: #1b4332;
  font-weight: 500;
}

.gear-meta {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.gear-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
}

.action-link { color: #d4a017; font-weight: 600; }
.action-del { color: #dc2626; }
.pick-btn { margin-top: 32rpx; }
.page-error { display: block; margin-top: 24rpx; text-align: center; }
.skeleton-wrap { margin-top: 24rpx; }
