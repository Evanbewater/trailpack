<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <text class="tab-icon">{{index === 0 ? '⛰' : index === 1 ? '📋' : '👤'}}</text>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
