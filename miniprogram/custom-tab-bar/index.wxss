.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 252, 245, 0.9);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 -4rpx 20rpx rgba(27, 67, 50, 0.06);
  display: flex;
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #5c6b5a;
}

.tab-item.active {
  color: #1b4332;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1.2;
}

.tab-text {
  font-size: 22rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  font-weight: 700;
}
