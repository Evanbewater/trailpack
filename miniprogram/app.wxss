page {
  background: #f7fbf4;
  color: #1b4332;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ── 晴天山林 · 共享页面层 ── */
.page-sunlit {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
}

.sunlit-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background:
    repeating-radial-gradient(
      circle at 68% 22%,
      transparent 0 64rpx,
      rgba(45, 106, 79, 0.04) 65rpx,
      transparent 66rpx
    ),
    radial-gradient(ellipse 70% 50% at 0% 0%, rgba(230, 184, 74, 0.22), transparent 58%),
    radial-gradient(ellipse 45% 35% at 100% 5%, rgba(125, 211, 252, 0.16), transparent 55%);
}

.page-inner {
  position: relative;
  z-index: 1;
}

.container {
  padding: 32rpx;
}

.card {
  background: rgba(255, 252, 245, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(27, 67, 50, 0.07);
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1b4332;
}

.subtitle {
  font-size: 26rpx;
  color: #3d5248;
  margin-top: 8rpx;
}

.btn-primary {
  background: linear-gradient(145deg, #e6b84a, #d4a017);
  color: #1b4332;
  font-weight: 700;
  border-radius: 20rpx;
  font-size: 30rpx;
  padding: 22rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(212, 160, 23, 0.35);
}

.btn-secondary {
  background: rgba(255, 252, 245, 0.86);
  color: #1b4332;
  font-weight: 600;
  border: 1rpx solid rgba(27, 67, 50, 0.1);
  border-radius: 20rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.tag-required { background: #fef2f2; color: #dc2626; }
.tag-suggest { background: #fffbeb; color: #b45309; }
.tag-optional { background: rgba(232, 245, 214, 0.9); color: #5c6b5a; }
.tag-demo { background: #fffbeb; color: #b45309; }
.tag-ai { background: rgba(232, 245, 214, 0.9); color: #2d6a4f; }

.text-muted { color: #5c6b5a; }
.text-error { color: #ef4444; }
.text-success { color: #2d6a4f; }

.page-with-tab {
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.skeleton {
  background: linear-gradient(90deg, rgba(255,252,245,0.6) 25%, rgba(232,245,214,0.8) 50%, rgba(255,252,245,0.6) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
  border-radius: 12rpx;
  height: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton-lg { height: 48rpx; width: 60%; }
.skeleton-block { height: 120rpx; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.tabs {
  display: flex;
  gap: 8rpx;
  margin: 24rpx 0;
  background: rgba(232, 245, 214, 0.7);
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #5c6b5a;
  border-radius: 12rpx;
}

.tab-btn.active {
  background: rgba(255, 252, 245, 0.95);
  color: #1b4332;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(27, 67, 50, 0.08);
}

.steps {
  margin: 24rpx 0;
}

.step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(27, 67, 50, 0.08);
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: rgba(232, 245, 214, 0.9);
  color: #5c6b5a;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-dot.done {
  background: linear-gradient(145deg, #e6b84a, #d4a017);
  color: #1b4332;
}
.step-dot.fail { background: #fef2f2; color: #dc2626; }
.step-dot.active { background: rgba(212, 160, 23, 0.15); color: #b8860b; }

.step-label { flex: 1; font-size: 26rpx; color: #1b4332; }
.step-action { font-size: 24rpx; color: #d4a017; font-weight: 600; }
